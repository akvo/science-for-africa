{
  "kind": "collectionType",
  "collectionName": "communities",
  "info": {
    "singularName": "community",
    "pluralName": "communities",
    "displayName": "Community",
    "description": "Professional communities within the Science for Africa platform"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "enum": ["General", "Technical", "Interest"],
      "default": "General"
    },
    "privacy": {
      "type": "enumeration",
      "enum": ["Public", "Private"],
      "default": "Public"
    },
    "status": {
      "type": "enumeration",
      "enum": ["Active", "Inactive"],
      "default": "Active"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "banner": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "memberCount": {
      "type": "integer",
      "default": 0
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::community.community",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::community.community",
      "mappedBy": "parent"
    },
    "memberships": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::community-membership.community-membership",
      "mappedBy": "community"
    }
  }
}
