{
  "kind": "singleType",
  "collectionName": "resources_pages",
  "info": {
    "singularName": "resources-page",
    "pluralName": "resources-pages",
    "displayName": "Resources Page",
    "description": "Editable hero content for the public resources page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "badge": {
      "type": "string",
      "default": "Explore Resources"
    },
    "title": {
      "type": "string",
      "required": true,
      "default": "Discover Our Valuable Resources"
    },
    "description": {
      "type": "text",
      "default": "Discover a variety of resources, from insightful case studies to comprehensive reports, that will enhance your understanding and exploration of the subject."
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
