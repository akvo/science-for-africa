{
  "kind": "collectionType",
  "collectionName": "individual_roles",
  "info": {
    "singularName": "individual-role",
    "pluralName": "individual-roles",
    "displayName": "Individual Role",
    "description": "User individual roles (e.g., Knowledge Consumer, Knowledge Contributor)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
