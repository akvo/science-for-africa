    User {
        string documentId PK
        string username UK
        string email UK
        string password
        string fullName
        text bio
        string orcidId
        enum careerStage "Early|Mid|Senior"
        enum educationLevel
        boolean mentorAvailability
        json notificationPreferences
        boolean confirmed
        boolean blocked
        boolean onboardingComplete
        json socialLinks
        datetime createdAt
        datetime updatedAt
    }

    Institution {
        string documentId PK
        string name UK
        enum type "Academic|Research|NGO|Government|Private"
        string country
        boolean verified
    }

    Community {
        string documentId PK
        string name UK
        string slug UK
        text description
        enum type "Community|SubCommunity"
        enum privacy "Public|Private|Restricted"
        enum status "Active|Archived"
        media logo
        media banner
        integer memberCount
    }

    CommunityMembership {
        string documentId PK
        enum role "admin|moderator|curator|member"
        datetime joinedAt
    }

    CommunityRule {
        string documentId PK
        string title
        text description
        integer sortOrder
    }

    ForumCategory {
        string documentId PK
        string name
        string slug UK
        text description
        integer sortOrder
        boolean isLocked
    }

    Thread {
        string documentId PK
        string title
        string slug UK
        richtext content
        boolean isPinned
        boolean isLocked
        boolean isAnswered
        integer viewCount
        integer replyCount
        datetime lastActivityAt
    }

    Post {
        string documentId PK
        richtext content
        enum status "pending|approved|declined"
        boolean isAcceptedAnswer
        string moderationReason
        integer upvoteCount
        datetime editedAt
    }

    CollaborationCall {
        string documentId PK
        string title
        richtext description
        datetime startDate
        datetime endDate
        enum status "Active|Completed"
        text goals
    }

    Resource {
        string documentId PK
        string title
        string slug UK
        richtext description
        enum resourceType "Publication|Training|Toolkit|Dataset|Other"
        media file
        string externalUrl
        integer downloadCount
        date publicationDate
    }

    Event {
        string documentId PK
        string title
        richtext description
        datetime startDatetime
        datetime endDatetime
        enum eventType "Webinar|Workshop|InPerson"
        string location
        string virtualLink
        integer maxParticipants
        boolean issuesCertificate
    }

    EventRegistration {
        string documentId PK
        enum status "registered|waitlisted|attended"
        datetime registeredAt
        boolean certificateIssued
    }

    MentorshipRelation {
        string documentId PK
        enum status "Requested|Active|Completed|Cancelled"
        text goals
        datetime startedAt
        datetime endedAt
    }

    Tag {
        string documentId PK
        string name UK
        string slug UK
        text description
        string color
        integer usageCount
    }

    Report {
        string documentId PK
        enum reason "Spam|Harassment|Misinformation|Other"
        text description
        enum status "Pending|Resolved|Dismissed"
        text moderatorNotes
        datetime resolvedAt
    }

    Notification {
        string documentId PK
        enum type "email_verification|password_reset|moderation|invite|event_reminder|mentorship|new_member"
        string subject
        text message
        enum status "sent|failed"
        json metadata
        datetime sentAt
    }

    SavedPost {
        string documentId PK
        datetime savedAt
    }

    Follow {
        string documentId PK
        datetime followedAt
    }
