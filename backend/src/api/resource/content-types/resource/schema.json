{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "Community resources such as reports, publications, practice notes and case studies"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "resourceType": {
      "type": "enumeration",
      "enum": ["report", "publication", "practice-note", "case-study"],
      "required": true
    },
    "file": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images", "files"]
    },
    "community": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::community.community"
    },
    "uploadedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "declined"],
      "default": "pending"
    },
    "topics": {
      "type": "json"
    }
  }
}
