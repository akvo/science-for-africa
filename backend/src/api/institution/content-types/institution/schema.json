{
  "kind": "collectionType",
  "collectionName": "institutions",
  "info": {
    "singularName": "institution",
    "pluralName": "institutions",
    "displayName": "Institution",
    "description": "Educational and Research Institutions"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "institutionType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::institution-type.institution-type",
      "inversedBy": "institutions"
    },
    "country": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::country.country",
      "inversedBy": "institutions"
    },
    "verified": {
      "type": "boolean",
      "default": false
    },
    "memberships": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::institution-membership.institution-membership",
      "mappedBy": "institution"
    },
    "alumni": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "highestEducationInstitution"
    }
  }
}
