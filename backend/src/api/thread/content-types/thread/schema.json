{
  "kind": "collectionType",
  "collectionName": "threads",
  "info": {
    "singularName": "thread",
    "pluralName": "threads",
    "displayName": "Thread"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "threads"
    },
    "forumCategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::forum-category.forum-category",
      "inversedBy": "threads"
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post",
      "mappedBy": "thread"
    },
    "followers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "followedThreads"
    },
    "isLocked": {
      "type": "boolean",
      "default": false
    },
    "isPinned": {
      "type": "boolean",
      "default": false
    }
  }
}
